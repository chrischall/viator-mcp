# Viator Partner API key — sign up as a Viator affiliate partner at
# https://partnerresources.viator.com/ (Basic Access is free). The key is the
# `exp-api-key` header value your account manager / partner portal gives you.
VIATOR_API_KEY=

# Optional: API base URL. Default is production (https://api.viator.com/partner).
# Sandbox keys only work against the sandbox host:
# VIATOR_API_BASE_URL=https://api.sandbox.viator.com/partner

# Optional: language for natural-language response fields (Accept-Language
# header). Default: en-US. See docs.viator.com for supported codes.
# VIATOR_LANGUAGE=en-US

# Optional: cache identical read responses for this many seconds to stay under
# the Viator rate limit (default: 60). Set to 0 to disable caching.
# VIATOR_CACHE_TTL=60

# Optional: longer cache TTL for reference data that rarely changes —
# destinations, tags, locations, exchange rates (default: 3600). 0 disables.
# VIATOR_STATIC_CACHE_TTL=3600
